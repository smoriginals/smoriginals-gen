        "folder-structure",
        "developer-tools"
    ],
    "author": "smoriginals",
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "chalk": "^5.3.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "eslint": "^10.1.0",
        "tsup": "^8.5.1",
        "typescript": "^5.3.3"
    }
}
