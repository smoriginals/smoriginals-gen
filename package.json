{
    "name": "folderplus",
    "version": "0.1.7",
    "description": "CLI utility for developers: trim code context, generate folder trees, and more",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "bin": {
        "folderplus": "./dist/cli.mjs"
    },
    "exports": {
        ".": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
