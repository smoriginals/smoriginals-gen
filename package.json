{
    "name": "folderplus",
    "version": "0.1.3",
    "description": "CLI utility for developers: trim code context, generate folder trees, and more",
    "type": "module",
    "bin": {
        "folderplus": "dist/cli.js"
    },
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "cli",
        "tree",
        "folder-structure",
        "developer-tools"
    ],
    "author": "smoriginals",
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "ora": "^9.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsup": "^8.5.1",
        "typescript": "^5.3.3"
    }
}
