{
  "name": "folderplus",
  "version": "2.0.5",
  "description": "Modern developer-friendly CLI tool to visualize project structures with filtering, JSON output, icons, and customizable ignore rules",
  "homepage": "https://github.com/smoriginals/folderplus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoriginals/folderplus.git"
  },
  "bugs": {
    "url": "https://github.com/smoriginals/folderplus/issues"
  },
  "license": "MIT",
  "author": "smoriginals",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "folderplus": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --test tests/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tree",
    "cli",
    "folder-tree",
    "directory-tree",
    "project-structure",
    "filesystem",
    "developer-tools",
    "json-tree",
    "nodejs-cli",
    "gitignore",
    "terminal",
    "file-explorer",
    "directory-visualizer",
    "folderplus",
    "smoriginals"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
